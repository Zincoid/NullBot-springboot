spring:
  application:
    name: NullBot
  servlet:
    multipart:
      max-file-size: 1024MB
      max-request-size: 1024MB
  datasource:
    driver-class-name: com.mysql.cj.jdbc.Driver
    url: jdbc:mysql://localhost:3306/NullBot
    username: root
    password:

server:
#  address: 127.0.0.1  # 仅监听本地回环
  port: 9001

#logging:
#  level:
#    org.apache.coyote: WARN
#    org.apache.tomcat: WARN
#    org.apache.catalina: WARN
#
#    org.apache.coyote.http11.Http11Processor: ERROR
#    org.apache.coyote.http11.Http11InputBuffer: ERROR

#logging:
#  level:
#    root: INFO
#    org.bot.nullbot: WARN

shiro:
  ws:
    server:
      enable: true
      url: /NullBot
    timeout: 20  # 10
    max-binary-message-buffer-size: 5120000
    max-text-message-buffer-size: 512000
    access-token:
  limiter:
    enable: true
    rate: 10
    capacity: 30
    awaitTask: true
    timeout: 20  # 10
#  task-pool:
#    core-pool-size: 10
#    queue-capacity: 200
#    keep-alive-time: 10
#    max-pool-size: 30
#    thread-name-prefix: "ShiroTaskPool-"

nullbot:
  bot-id: 0000000000
  enable-image-collect: false
  enable-message-collect: false  # 使用AI Monitor模式及Recall Detect功能 需启用该项
  enable-keyword-detect: true
  enable-poke-detect: true
  enable-recall-detect: false
  command:
    prefix: /
    rate-limit:
      enabled: true
      capacity: 25
      refill: 10
      scope: group
  file:
    storage:
      file-directory: /root/Nullbot/file  # src/main/resources/file
      temp-path: /root/Nullbot/file/temp  # src/main/resources/file/temp
      image-path: /root/Nullbot/file/image  # src/main/resources/file/image
      video-path: /root/Nullbot/file/video  # src/main/resources/file/video
      audio-path: /root/Nullbot/file/audio  # src/main/resources/file/audio
  accesses:
    0000000001: 2
  group-black-list:
    0000000002

ai:
  deepseek:
    api-key:
    api-url: https://api.deepseek.com/chat/completions
    max-history-length: 50
    max-monitor-length: 200
    max-tokens: 500
    system-message:
      group: "你是一个猫娘，你的名字叫Null，你的主人是Zincoid，他的ID是2660181154。
              你在一个群聊中，不同用户的消息会带有他们的标识，如[userName(userId)]，请根据标识区分不同用户。
              你可以回答别人的问题不用经过主人同意，回复消息时不要带以上那种格式化的标识。"
      personal: "你是一个助手，你的名字叫Null。"
      monitor: "你是一个猫娘，你的名字叫Null。你在一个群聊中不断监听着所有人的消息。
              不同用户的消息会带有他们的标识，如[userName(userId)]，请根据标识区分不同用户，回复消息时不要带这种格式化的标识。"
